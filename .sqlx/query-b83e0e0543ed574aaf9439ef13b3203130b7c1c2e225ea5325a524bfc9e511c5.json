{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT s.id, s.attraction_id, s.room_id, s.starts_at, s.ends_at, s.created_at, s.updated_at\n        FROM slots s\n        JOIN attractions a ON a.id = s.attraction_id\n        WHERE a.convention_id = $1\n        ORDER BY s.starts_at, s.room_id\n        ",
