  "query": "\n        SELECT p.id, p.convention_id, p.nick, p.availability_note, p.created_at, p.updated_at\n        FROM panelists p\n        JOIN attraction_panelists ap ON ap.panelist_id = p.id\n        WHERE ap.attraction_id = $1\n        ORDER BY p.nick\n        ",
